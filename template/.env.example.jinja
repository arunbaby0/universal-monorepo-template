# =============================================================================
# Local Development Environment
# Copy to .env and fill in values: cp .env.example .env
# =============================================================================

# Database
# Local: Docker Compose provides this automatically
# Production: Use Neon (neon.tech), Supabase, or Vercel Postgres
DATABASE_URL=postgresql://dev:dev@localhost:5432/{{ project_name | replace("-", "_") }}

# Auth - BetterAuth
# Generate secret: openssl rand -base64 32
# Production: Use a unique, strong secret (never reuse across environments)
BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars
# Production: Set to your deployed URL (e.g., https://myapp.vercel.app)
BETTER_AUTH_URL=http://localhost:3000

{% if auth_providers in ["email_google", "email_google_apple"] -%}
# OAuth - Google
# Get credentials: https://console.cloud.google.com/apis/credentials
# Set authorized redirect URI to: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
{%- endif %}

{% if auth_providers == "email_google_apple" -%}
# OAuth - Apple
# Get credentials: https://developer.apple.com/account/resources/identifiers
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
{%- endif %}

{% if include_payments -%}
# Stripe
# Get keys: https://dashboard.stripe.com/apikeys
# Production: Switch from test keys (pk_test_/sk_test_) to live keys (pk_live_/sk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Webhook secret: https://dashboard.stripe.com/webhooks (or use stripe listen --forward-to for local)
STRIPE_WEBHOOK_SECRET=
{%- endif %}

# API URLs
# Production: Set to your deployed URL
NEXT_PUBLIC_API_URL=http://localhost:3000
{% if include_mobile -%}
EXPO_PUBLIC_API_URL=http://localhost:3000
{%- endif %}

# Environment
NODE_ENV=development
