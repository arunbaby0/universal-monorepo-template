# Database
DATABASE_URL=postgresql://dev:dev@localhost:5432/{{ project_name | replace("-", "_") }}

# Auth - BetterAuth
BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

{% if auth_providers in ["email_google", "email_google_apple"] -%}
# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
{%- endif %}

{% if auth_providers == "email_google_apple" -%}
# OAuth - Apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
{%- endif %}

{% if include_payments -%}
# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
{%- endif %}

# API URLs
NEXT_PUBLIC_API_URL=http://localhost:3000
{% if include_mobile -%}
EXPO_PUBLIC_API_URL=http://localhost:3000
{%- endif %}

# Environment
NODE_ENV=development
