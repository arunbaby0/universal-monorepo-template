{
  "name": "{{ project_name }}",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/modules/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=web",
{%- if include_mobile %}
    "dev:mobile": "turbo run dev --filter=mobile",
{%- endif %}
{%- if include_desktop %}
    "dev:desktop": "turbo run dev --filter=desktop",
{%- endif %}
{%- if include_storybook %}
    "dev:storybook": "turbo run storybook --filter=web",
{%- endif %}
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "db:migrate": "bun run --cwd packages/db migrate",
    "db:generate": "bun run --cwd packages/db generate",
    "db:push": "bun run --cwd packages/db push",
    "db:studio": "bun run --cwd packages/db studio",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "turbo": "^2.8.0",
    "typescript": "^5.7.2"
  }
}
